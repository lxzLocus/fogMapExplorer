# Copy to `.env` and adjust. docker-compose reads this automatically.

# --- database ---
POSTGRES_USER=fog
POSTGRES_PASSWORD=change-me
POSTGRES_DB=fogexplorer

# --- auth ---
# Secret used to sign login tokens (JWT). Use a long random string in production,
# e.g. `openssl rand -hex 32`.
JWT_SECRET=dev-insecure-secret-change-me

# --- app ---
# Host port the app (PWA + API in one image) is served on -> http://localhost:8080
APP_PORT=8080

# --- optional: run the prebuilt image from GHCR instead of building locally ---
# Set this and run `docker compose pull && docker compose up -d`.
# APP_IMAGE=ghcr.io/<owner>/<repo>:latest
