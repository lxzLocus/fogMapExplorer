# Copy to `.env` and adjust. docker-compose reads this automatically.

# --- database ---
POSTGRES_USER=fog
POSTGRES_PASSWORD=change-me
POSTGRES_DB=fogexplorer

# --- auth ---
# Secret used to sign login tokens (JWT). Use a long random string in production,
# e.g. `openssl rand -hex 32`.
JWT_SECRET=dev-insecure-secret-change-me

# --- frontend ---
# Host port the PWA is served on -> http://localhost:8080
FRONT_PORT=8080

# --- optional: run prebuilt images from GHCR instead of building locally ---
# Set these and run `docker compose pull && docker compose up -d`.
# FRONT_IMAGE=ghcr.io/<owner>/fogmapexplorer-frontend:latest
# BACKEND_IMAGE=ghcr.io/<owner>/fogmapexplorer-backend:latest
